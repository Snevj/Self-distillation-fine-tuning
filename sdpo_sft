{"cell_type":"code","source":"\"\"\"\nEvaluate base / SFT / SDPO models on GSM8K and write eval_results.json\nRun this BEFORE visualise_results.py\n\"\"\"\nimport json\nimport re\nimport random\nfrom datasets import load_dataset\nfrom unsloth import FastLanguageModel\nfrom unsloth.chat_templates import get_chat_template\nfrom tqdm import tqdm\n\n# ── CONFIG ──────────────────────────────────────────────────────────────────\n# EDIT THESE PATHS to match your actual checkpoints\nMODEL_PATHS = {\n    \"base\": \"unsloth/llama-3-8b-Instruct-bnb-4bit\",\n    \"sft\":  \"svjay/sdpo-llama-3-8b-sft\",\n    \"sdpo\": \"svjay/sdpo-llama-3-8b-v2\",\n}\n\nN_SAMPLES = 50           # number of GSM8K test questions to evaluate on (kept small for Kaggle session limits)\nRESULTS_PATH = \"eval_results.json\"\nMAX_SEQ_LENGTH = 2048\nMAX_NEW_TOKENS = 512\nSEED = 42\n\n# ── HELPERS ─────────────────────────────────────────────────────────────────\ndef extract_gold_answer(answer_text: str) -> str:\n    \"\"\"GSM8K gold answers end with '#### <number>'.\"\"\"\n    match = re.search(r\"####\\s*(-?[\\d,]+(?:\\.\\d+)?)\", answer_text)\n    if not match:\n        return None\n    return match.group(1).replace(\",\", \"\").strip()\n\n\ndef extract_pred_answer(generated_text: str) -> str:\n    \"\"\"Pull the last number out of the model's generated response.\"\"\"\n    # Prefer an explicit '#### number' if the model was prompted to use that format\n    match = re.search(r\"####\\s*(-?[\\d,]+(?:\\.\\d+)?)\", generated_text)\n    if match:\n        return match.group(1).replace(\",\", \"\").strip()\n    # Fallback: last number in the text\n    numbers = re.findall(r\"-?[\\d,]+(?:\\.\\d+)?\", generated_text)\n    if not numbers:\n        return None\n    return numbers[-1].replace(\",\", \"\").strip()\n\n\ndef numbers_match(pred: str, gold: str) -> bool:\n    if pred is None or gold is None:\n        return False\n    try:\n        return abs(float(pred) - float(gold)) < 1e-4\n    except ValueError:\n        return pred == gold\n\n\ndef build_prompt(question: str) -> str:\n    return (\n        f\"Solve the following grade-school math problem step by step. \"\n        f\"End your answer with '#### <final numeric answer>'.\\n\\n\"\n        f\"Question: {question}\\n\\nAnswer:\"\n    )\n\n\ndef evaluate_model(model_name: str, model_path: str, eval_set) -> dict:\n    print(f\"\\n{'='*60}\\nLoading {model_name}: {model_path}\\n{'='*60}\")\n    model, tokenizer = FastLanguageModel.from_pretrained(\n        model_name=model_path,\n        max_seq_length=MAX_SEQ_LENGTH,\n        dtype=None,\n        load_in_4bit=True,\n    )\n    tokenizer = get_chat_template(tokenizer, chat_template=\"llama-3\")\n    FastLanguageModel.for_inference(model)\n\n    correct = 0\n    total = 0\n\n    for example in tqdm(eval_set, desc=f\"Evaluating {model_name}\"):\n        question = example[\"question\"]\n        gold = extract_gold_answer(example[\"answer\"])\n        if gold is None:\n            continue\n\n        messages = [{\"role\": \"user\", \"content\": build_prompt(question)}]\n        inputs = tokenizer.apply_chat_template(\n            messages, tokenize=True, add_generation_prompt=True, return_tensors=\"pt\"\n        ).to(model.device)\n\n        outputs = model.generate(\n            input_ids=inputs,\n            max_new_tokens=MAX_NEW_TOKENS,\n            use_cache=True,\n            temperature=0.0,\n            do_sample=False,\n        )\n        generated = tokenizer.decode(\n            outputs[0][inputs.shape[-1]:], skip_special_tokens=True\n        )\n        pred = extract_pred_answer(generated)\n\n        total += 1\n        if numbers_match(pred, gold):\n            correct += 1\n\n    accuracy = round(100 * correct / total, 1) if total > 0 else 0.0\n    print(f\"{model_name}: {correct}/{total} correct -> {accuracy}%\")\n\n    # Free GPU memory before loading the next model\n    del model, tokenizer\n    import torch, gc\n    gc.collect()\n    torch.cuda.empty_cache()\n\n    return {\"model\": model_name, \"accuracy\": accuracy, \"correct\": correct, \"total\": total}\n\n\n# ── MAIN ────────────────────────────────────────────────────────────────────\ndef load_existing_results() -> dict:\n    \"\"\"Resume support: load whatever's already been saved, if anything.\"\"\"\n    try:\n        with open(RESULTS_PATH) as f:\n            data = json.load(f)\n        return {m[\"model\"]: m for m in data.get(\"metrics\", [])}\n    except (FileNotFoundError, json.JSONDecodeError):\n        return {}\n\n\ndef save_results(results_by_model: dict, n_samples: int):\n    output = {\n        \"metrics\": list(results_by_model.values()),\n        \"n_samples\": n_samples,\n        \"seed\": SEED,\n    }\n    with open(RESULTS_PATH, \"w\") as f:\n        json.dump(output, f, indent=2)\n\n\ndef main():\n    random.seed(SEED)\n    print(\"Loading GSM8K test set...\")\n    dataset = load_dataset(\"openai/gsm8k\", \"main\", split=\"test\")\n    indices = random.sample(range(len(dataset)), min(N_SAMPLES, len(dataset)))\n    eval_set = dataset.select(indices)\n    print(f\"Evaluating on {len(eval_set)} samples\")\n\n    results_by_model = load_existing_results()\n    if results_by_model:\n        print(f\"Resuming — already have results for: {list(results_by_model.keys())}\")\n\n    for model_name, model_path in MODEL_PATHS.items():\n        if model_name in results_by_model:\n            print(f\"Skipping {model_name} (already evaluated)\")\n            continue\n        result = evaluate_model(model_name, model_path, eval_set)\n        results_by_model[model_name] = result\n        save_results(results_by_model, len(eval_set))\n        print(f\"Saved progress after {model_name} -> {RESULTS_PATH}\")\n\n    print(\"\\nAll done.\")\n    print(json.dumps(list(results_by_model.values()), indent=2))\n\n\nif __name__ == \"__main__\":\n    main()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-20T19:30:07.810041Z","iopub.execut