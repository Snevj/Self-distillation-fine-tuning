_type":"code","source":"import os\nimport re\nimport sys\nimport subprocess\n\n# This is the exact code that will be written into sdpo.py\nsdpo_code = r'''import os\nimport re\nimport torch\n\n_hf_token = os.environ.get(\"HF_TOKEN\")\nif not _hf_token:\n    raise EnvironmentError(\"HF_TOKEN secret not found.\")\nos.environ[\"HUGGING_FACE_HUB_TOKEN\"] = _hf_token\nos.environ[\"HF_TOKEN\"] = _hf_token\n\nos.environ[\"UNSLOTH_FORCE_FP16\"] = \"1\"\nos.environ[\"PYTORCH_ALLOC_CONF\"] = \"expandable_segments:True\"\nos.environ[\"TRACKIO_PROJECT\"] = \"my-sdpo-alignment\"\nos.environ[\"TRACKIO_SPACE_ID\"] = \"Snevj/my-training-dashboard\"\n\nfrom datasets import load_dataset\nfrom unsloth import FastLanguageModel, is_bfloat16_supported\nfrom unsloth.chat_templates import get_chat_template\nfrom trl.experimental.sdpo import SDPOConfig, SDPOTrainer\nfrom transformers import GenerationConfig\n\nmax_seq_length = 2048\nSFT_OUTPUT = \"/kaggle/working/Self-distillation-fine-tuning/outputs-sft\"\n\n# 1. Load the SFT model (automatically includes your previous LoRA adapters)\nmodel, tokenizer = FastLanguageModel.from_pretrained(\n    model_name=SFT_OUTPUT,\n    max_seq_length=max_seq_length,\n    dtype=None,\n    load_in_4bit=True,\n)\ntokenizer = get_chat_template(tokenizer, chat_template=\"llama-3\")\n\n# Set up model for training without nested double-PEFT adapters\nFastLanguageModel.for_training(model)\n\n# 2. Add explicit generation settings to break flat/deterministic rewards\ngeneration_config = GenerationConfig(\n    max_new_tokens=256,\n    do_sample=True,\n    temperature=0.7,\n    top_p=0.9,\n    pad_token_id=tokenizer.pad_token_id,\n    eos_token_id=tokenizer.eos_token_id,\n)\n\n# 3. Robust reward function targeting the final generated number\ndef accuracy_reward_fn(completions, answer, **kwargs):\n    rewards = []\n    for completion, gt_answer in zip(completions, answer):\n        if isinstance(completion, list):\n            text = \" \".join(\n                m[\"content\"] for m in completion\n                if isinstance(m, dict) and m.get(\"role\") == \"assistant\"\n            ) or \" \".join(str(m) for m in completion)\n        else:\n            text = str(completion)\n        \n        gt_match = re.search(r\"####\\s*(-?\\d+)\", str(gt_answer))\n        gt_num = gt_match.group(1) if gt_match else str(gt_answer).strip()\n        \n        numbers = re.findall(r\"-?\\d+\", text)\n        final_pred = numbers[-1] if numbers else None\n        \n        rewards.append(1.0 if final_pred == gt_num else 0.0)\n    return rewards\n\nraw_dataset = load_dataset(\"gsm8k\", \"main\", split=\"train[:1000]\")\n\ndef format_prompt(examples):\n    return {\n        \"prompt\": [[{\"role\": \"user\", \"content\": q}] for q in examples[\"question\"]],\n        \"answer\": examples[\"answer\"],\n    }\n\ndataset = raw_dataset.map(format_prompt, batched=True, remove_columns=raw_dataset.column_names)\n\ntraining_args = SDPOConfig(\n    output_dir=\"outputs-sdpo\",\n    max_steps=150,\n    per_device_train_batch_size=1,\n    gradient_accumulation_steps=8,\n    learning_rate=5e-5,\n    fp16=not is_bfloat16_supported(),\n    bf16=is_bfloat16_supported(),\n    logging_steps=1,\n    optim=\"adamw_8bit\",\n    num_generations=4,\n    distillation_weight=1.0,\n    distillation_mode=\"topk_logits\",\n    distillation_topk=100,\n    teacher_model_kind=\"ema\",\n    use_vllm=False,\n    success_reward_threshold=0.1,  # Lowered to ensure distillation engages easily\n    report_to=\"trackio\",\n    run_name=\"sdpo_alignment_run_02\",\n)\n\ntrainer = SDPOTrainer(\n    model=model,\n    processing_class=tokenizer,\n    args=training_args,\n    train_dataset=dataset,\n    reward_funcs=[accuracy_reward_fn],\n    generation_config=generation_config,\n)\n\nprint(\"Starting SDPO training loop...\")\ntrainer.train()\n\nmodel.save_pretrained(\"outputs-sdpo\")\nprint(\"SDPO complete!\")\n\nprint(\"Quantizing to GGUF...\")\nmodel.save_pretrained_gguf(\"outputs_sdpo_gguf\", tokenizer, quantization_method=\"q4_k_m\")\nprint(\"Pipeline complete!\")\n'''\n\n# Create directory structure if it doesn't exist yet\nos.makedirs(\"/kaggle/working/Self-distillation-fine-tuning/src\", exist_ok=True)\n\n# Write out the script\nwith open(\"/kaggle/working/Self-distillation-fine-tuning/src/sdpo.py\", \"w\") as f:\n    f.write(sdpo_code)\n\n# Verify script content\nwith open(\"/kaggle/working/Self-distillation-fine-tuning/src/sdpo.py\", \"r\") as f:\n    content = f.read()\nassert \"####\" in content, \"❌ Reward fix missing!\"\nprint(\"✅ sdpo.py fully rewritten\")\n\n# Execute the script as a subprocess from the correct folder context\nresult = subprocess.run([sys.executable, \"src/sdpo.py\"], cwd=\"/kaggle/working/Self-distillation-fine-tuning\", env=os.environ.copy())","metadata":{"trusted":true},"outputs":[],"execution_count":null}]}